# crux-console connects to crux-server over HTTP
# URL of the crux-server API (adjust for Docker Compose or remote deployments)
CRUX_CONSOLE_API_URL=http://localhost:7700

# Auth mode: "none" | "apikey" | "oidc" (OIDC requires V0.2+)
CRUX_CONSOLE_AUTH_MODE=none

# API key — set when CRUX_CONSOLE_AUTH_MODE=apikey
CRUX_CONSOLE_API_KEY=

# Port the console listens on (default 7780)
CRUX_CONSOLE_PORT=7780
